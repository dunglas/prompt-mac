# Identity (user.name / user.email) is personal and lives in git's XDG config
# (~/.config/git/config), which install.sh populates. This file stays generic.
[user]
	signingkey = ~/.ssh/id_ed25519.pub
[gpg]
	format = ssh
[gpg "ssh"]
	allowedSignersFile = ~/.config/git/allowed_signers
[commit]
	gpgsign = true
[tag]
	gpgsign = true
